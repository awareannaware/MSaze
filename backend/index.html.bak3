<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Campus Navigator</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#0d0f14;--surface:#161920;--surface2:#1e2230;--border:#2a2f3d;
  --accent:#4f9eff;--accent2:#00e5a0;--warn:#ffb347;
  --text:#e8ecf4;--muted:#6b7591;
  --wall21:#c8d8f0;--wall22:#f0c8a0;
  --route:#00e5a0;--start:#ffb347;--stairs:#00e5a0;--elev:#bf7fff;
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);height:100vh;display:flex;flex-direction:column;overflow:hidden}

header{padding:13px 20px;display:flex;align-items:center;gap:12px;border-bottom:1px solid var(--border);background:var(--surface);flex-shrink:0}
.logo{font-family:'Space Mono',monospace;font-size:16px;font-weight:700;color:var(--accent)}
.logo span{color:var(--accent2)}
.sub{font-size:11px;color:var(--muted);margin-top:1px}

.main{display:flex;flex:1;overflow:hidden}

/* Panel */
.panel{width:300px;flex-shrink:0;background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;overflow:hidden}
.search-box{padding:16px;border-bottom:1px solid var(--border);flex-shrink:0}
.lbl{font-size:9px;font-weight:600;letter-spacing:1.5px;color:var(--muted);text-transform:uppercase;margin-bottom:4px}
.inp-wrap{position:relative;margin-bottom:8px}
.inp-wrap .ico{position:absolute;left:9px;top:50%;transform:translateY(-50%);font-size:12px;pointer-events:none}
input[type=text]{width:100%;background:var(--surface2);border:1px solid var(--border);border-radius:7px;color:var(--text);font-family:'DM Sans',sans-serif;font-size:13px;padding:8px 9px 8px 29px;outline:none;transition:border-color .2s}
input[type=text]:focus{border-color:var(--accent)}
input[type=text]::placeholder{color:var(--muted)}
.drop{position:absolute;top:calc(100% + 3px);left:0;right:0;background:var(--surface2);border:1px solid var(--border);border-radius:7px;max-height:170px;overflow-y:auto;z-index:200;display:none}
.drop.show{display:block}
.di{padding:8px 11px;cursor:pointer;font-size:12px;display:flex;justify-content:space-between;align-items:center;transition:background .1s;gap:8px}
.di:hover{background:var(--border)}
.rid{font-family:'Space Mono',monospace;font-size:11px;color:var(--accent);font-weight:700;white-space:nowrap}
.rinfo{font-size:10px;color:var(--muted);text-align:right;white-space:nowrap}
.swap-btn{width:100%;background:transparent;border:1px dashed var(--border);border-radius:6px;color:var(--muted);font-size:11px;padding:5px;cursor:pointer;transition:all .2s;margin-bottom:8px}
.swap-btn:hover{border-color:var(--accent);color:var(--accent)}
.route-btn{width:100%;background:var(--accent);border:none;border-radius:7px;color:#0d0f14;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:600;padding:10px;cursor:pointer;transition:all .2s;display:flex;align-items:center;justify-content:center;gap:6px}
.route-btn:hover{background:#74b3ff;transform:translateY(-1px)}
.route-btn:disabled{opacity:.4;cursor:not-allowed;transform:none}

/* Steps */
.steps-area{flex:1;overflow-y:auto;padding:12px 14px}
.steps-area::-webkit-scrollbar{width:3px}
.steps-area::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}
.summary{background:var(--surface2);border:1px solid var(--border);border-radius:9px;padding:11px 13px;margin-bottom:12px;display:flex;gap:12px}
.stat{flex:1;text-align:center}
.sv{font-family:'Space Mono',monospace;font-size:19px;font-weight:700;color:var(--accent);line-height:1}
.sk{font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-top:3px}
.sdiv{width:1px;background:var(--border)}
.steps-lbl{font-size:9px;font-weight:600;letter-spacing:1.5px;color:var(--muted);text-transform:uppercase;margin-bottom:7px}
.step{display:flex;gap:9px;margin-bottom:3px;position:relative}
.step:not(:last-child) .sline{position:absolute;left:12px;top:26px;bottom:-3px;width:2px;background:var(--border)}
.sico{width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;flex-shrink:0;border:2px solid}
.sico.start{background:rgba(79,158,255,.15);border-color:var(--accent);color:var(--accent)}
.sico.walk{background:rgba(79,158,255,.06);border-color:var(--border);color:var(--muted)}
.sico.stairs{background:rgba(0,229,160,.12);border-color:var(--stairs);color:var(--stairs)}
.sico.elevator{background:rgba(191,127,255,.12);border-color:var(--elev);color:var(--elev)}
.sico.arrived{background:rgba(255,179,71,.15);border-color:var(--warn);color:var(--warn)}
.stxt{flex:1;padding:4px 0;font-size:12px;line-height:1.4}
.stxt.start,.stxt.arrived{font-weight:600}
.stxt.stairs{color:var(--stairs);font-weight:500}
.stxt.elevator{color:var(--elev);font-weight:500}
.floor-btn{margin-top:3px;background:transparent;border:1px solid var(--border);border-radius:4px;color:var(--muted);font-size:9px;padding:2px 7px;cursor:pointer;transition:all .15s}
.floor-btn:hover{border-color:var(--accent);color:var(--accent)}
.empty{text-align:center;padding:24px 14px;color:var(--muted)}
.empty .ei{font-size:26px;margin-bottom:6px}
.empty .em{font-size:12px;line-height:1.5}
.err{background:rgba(255,80,80,.1);border:1px solid rgba(255,80,80,.3);border-radius:7px;padding:8px 11px;font-size:12px;color:#ff6060;margin-bottom:9px;display:none}
.err.show{display:block}
.loading{display:flex;align-items:center;gap:8px;color:var(--muted);font-size:12px;padding:16px;justify-content:center}
.spin{width:13px;height:13px;border:2px solid var(--border);border-top-color:var(--accent);border-radius:50%;animation:spin .7s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}

/* Map */
.map-area{flex:1;position:relative;background:#080a10;overflow:hidden}
#mapCanvas{width:100%;height:100%;cursor:grab;display:block}
#mapCanvas:active{cursor:grabbing}
.floor-tabs{position:absolute;top:12px;left:12px;display:flex;gap:4px;z-index:10}
.ftab{background:var(--surface);border:1px solid var(--border);border-radius:5px;padding:4px 10px;font-size:11px;font-weight:500;color:var(--muted);cursor:pointer;transition:all .15s}
.ftab.active{background:var(--accent);border-color:var(--accent);color:#0d0f14;font-weight:700}
.map-ctrl{position:absolute;bottom:16px;right:16px;display:flex;flex-direction:column;gap:4px;z-index:10}
.mbtn{width:32px;height:32px;background:var(--surface);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:15px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .15s}
.mbtn:hover{border-color:var(--accent);color:var(--accent)}
.legend{position:absolute;bottom:16px;left:16px;background:rgba(22,25,32,.92);border:1px solid var(--border);border-radius:7px;padding:8px 11px;font-size:10px;display:flex;flex-direction:column;gap:4px;z-index:10}
.leg{display:flex;align-items:center;gap:6px;color:var(--muted)}
.lline{width:14px;height:2px;flex-shrink:0;border-radius:1px}
.ldot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
</style>
</head>
<body>
<header>
  <div>
    <div class="logo">campus<span>nav</span></div>
    <div class="sub">Buildings 21 &amp; 22 · 2D Floor Map</div>
  </div>
</header>
<div class="main">
  <div class="panel">
    <div class="search-box">
      <div class="lbl">From</div>
      <div class="inp-wrap">
        <span class="ico">📍</span>
        <input type="text" id="fromInput" placeholder="Room number or type..." autocomplete="off">
        <div class="drop" id="fromDrop"></div>
      </div>
      <button class="swap-btn" onclick="swapRooms()">⇅ Swap</button>
      <div class="lbl">To</div>
      <div class="inp-wrap">
        <span class="ico">🏁</span>
        <input type="text" id="toInput" placeholder="Room number or type..." autocomplete="off">
        <div class="drop" id="toDrop"></div>
      </div>
      <div class="err" id="errBanner"></div>
      <button class="route-btn" id="routeBtn" onclick="getRoute()" disabled>🗺 Find Route</button>
    </div>
    <div class="steps-area" id="stepsArea">
      <div class="empty"><div class="ei">🧭</div><div class="em">Enter a start and destination to find the shortest path.</div></div>
    </div>
  </div>

  <div class="map-area">
    <div class="floor-tabs" id="floorTabs"></div>
    <canvas id="mapCanvas"></canvas>
    <div class="map-ctrl">
      <button class="mbtn" onclick="zoomIn()">+</button>
      <button class="mbtn" onclick="zoomOut()">−</button>
      <button class="mbtn" onclick="resetView()">⌂</button>
    </div>
    <div class="legend">
      <div class="leg"><div class="lline" style="background:var(--wall21);opacity:.7"></div>Walls Bldg 21</div>
      <div class="leg"><div class="lline" style="background:var(--wall22);opacity:.7"></div>Walls Bldg 22</div>
      <div class="leg"><div class="lline" style="background:var(--route);height:3px"></div>Route</div>
      <div class="leg"><div class="ldot" style="background:var(--start)"></div>Start / End</div>
      <div class="leg"><div class="ldot" style="background:#aaa;opacity:.6"></div>Door</div>
    </div>
  </div>
</div>

<script>
const API = '';
const RESTROOM = ['שירותים','שרותים','שירותי נכים','שרותי נכים'];

let allRooms=[], fromRoom=null, toRoom=null;
let currentRoute=null, currentFloor=3;
let floorCache={};   // floor_num → floormap API response

let canvas, ctx;
let panX=0, panY=0, scale=1;
let isPan=false, lmx=0, lmy=0;

// ── Init ─────────────────────────────────────────────────────────────────────
async function init() {
  canvas=document.getElementById('mapCanvas'); ctx=canvas.getContext('2d');
  resize(); window.addEventListener('resize',resize);
  setupPan(); setupTabs();
  try{ const r=await fetch(`${API}/api/rooms?q=`); allRooms=await r.json(); }catch(e){}
  setupAC('fromInput','fromDrop',r=>{fromRoom=r;checkReady();switchFloor(r.floor);});
  setupAC('toInput',  'toDrop',  r=>{toRoom=r;  checkReady();});
  await loadFloor(currentFloor);
}

function resize(){
  const p=canvas.parentElement;
  canvas.width=p.clientWidth; canvas.height=p.clientHeight; draw();
}

// ── Floor tabs ────────────────────────────────────────────────────────────────
function setupTabs(){
  const tabs=document.getElementById('floorTabs');
  for(let f=1;f<=6;f++){
    const b=document.createElement('button');
    b.className='ftab'+(f===currentFloor?' active':'');
    b.textContent=`F${f}`; b.dataset.f=f;
    b.onclick=()=>switchFloor(f);
    tabs.appendChild(b);
  }
}

async function switchFloor(f){
  f=parseInt(f); if(!f||f<1||f>6) return;
  currentFloor=f;
  document.querySelectorAll('.ftab').forEach(b=>b.classList.toggle('active',parseInt(b.dataset.f)===f));
  await loadFloor(f);
}

async function loadFloor(f){
  if(!floorCache[f]){
    try{
      const r=await fetch(`${API}/api/floormap/${f}`);
      floorCache[f]=await r.json();
    }catch(e){ console.warn('floormap load failed',e); }
  }
  resetView();
}

// ── Coordinate transform ──────────────────────────────────────────────────────
function toC(wx,wy){
  const d=floorCache[currentFloor]; if(!d)return[0,0];
  const {x_min,x_max,y_min,y_max}=d.bounds;
  const pad=30;
  const vw=canvas.width-pad*2, vh=canvas.height-pad*2;
  const dw=x_max-x_min, dh=y_max-y_min;
  const sc=Math.min(vw/dw, vh/dh);
  const ox=pad+(vw-dw*sc)/2, oy=pad+(vh-dh*sc)/2;
  return[
    panX + ox + (wx-x_min)*sc*scale,
    panY + oy + (y_max-wy)*sc*scale,
  ];
}

// ── Draw ──────────────────────────────────────────────────────────────────────
function draw(){
  if(!ctx)return;
  ctx.clearRect(0,0,canvas.width,canvas.height);
  const d=floorCache[currentFloor];
  if(!d){ctx.fillStyle='rgba(107,117,145,.3)';ctx.font='13px DM Sans,sans-serif';ctx.textAlign='center';ctx.fillText('Loading…',canvas.width/2,canvas.height/2);return;}

  const routeSet  = new Set();
  const routeArr  = [];

  // ── 1. Walls ──
  const drawWalls=(walls,color)=>{
    ctx.strokeStyle=color; ctx.lineWidth=1.2*scale; ctx.lineCap='round';
    walls.forEach(l=>{
      const[x1,y1]=toC(l.start[0],l.start[1]);
      const[x2,y2]=toC(l.end[0],  l.end[1]);
      ctx.beginPath(); ctx.moveTo(x1,y1); ctx.lineTo(x2,y2); ctx.stroke();
    });
  };
  drawWalls(d.walls_b21,'rgba(200,216,240,.55)');
  drawWalls(d.walls_b22,'rgba(240,200,160,.55)');

  // ── 2. Route highlight — corridor path ──
  if(currentRoute && currentRoute.corridor_path){
    const pts = currentRoute.corridor_path.filter(cn=>cn.floor===currentFloor);
    if(pts.length>=2){
      // glow
      ctx.beginPath(); ctx.strokeStyle='rgba(0,229,160,.12)'; ctx.lineWidth=20*scale; ctx.lineCap='round'; ctx.lineJoin='round';
      pts.forEach((cn,i)=>{ const[x,y]=toC(cn.x,cn.y); i===0?ctx.moveTo(x,y):ctx.lineTo(x,y); });
      ctx.stroke();
      // line
      ctx.beginPath(); ctx.strokeStyle='#00e5a0'; ctx.lineWidth=3*scale;
      pts.forEach((cn,i)=>{ const[x,y]=toC(cn.x,cn.y); i===0?ctx.moveTo(x,y):ctx.lineTo(x,y); });
      ctx.stroke();
      // dots on corridor nodes
      pts.forEach(cn=>{
        const[x,y]=toC(cn.x,cn.y);
        ctx.beginPath(); ctx.arc(x,y,3*scale,0,Math.PI*2);
        ctx.fillStyle='rgba(0,229,160,.6)'; ctx.fill();
      });
    }
  }

  // ── 3. Room doors + labels ──
  d.rooms.forEach(r=>{
    const[dx,dy]=toC(r.door_x,r.door_y);
    const inRoute =routeSet.has(r.id);
    const isStart =routeArr.length&&r.id===routeArr[0];
    const isEnd   =routeArr.length&&r.id===routeArr[routeArr.length-1];
    const isPicked=(fromRoom&&r.id===fromRoom.id)||(toRoom&&r.id===toRoom.id);
    const isRR    =RESTROOM.some(t=>r.type&&r.type.startsWith(t.substring(0,4)));

    // Door notch on wall
    const dotR = inRoute ? Math.max(3,4*scale) : Math.max(2,2.5*scale);
    let col = r.building==='22'?'rgba(240,200,160,.7)':'rgba(200,216,240,.7)';
    if(inRoute) col='#00e5a0';
    if(isStart||isEnd||isPicked) col='#ffb347';
    if(isStart||isEnd||isPicked){
      ctx.beginPath(); ctx.arc(dx,dy,dotR+5*scale,0,Math.PI*2);
      ctx.fillStyle=col+'30'; ctx.fill();
    }
    ctx.beginPath(); ctx.arc(dx,dy,dotR,0,Math.PI*2);
    ctx.fillStyle=col; ctx.fill();

    // Labels — only for route rooms or picked rooms
    if(!inRoute && !isPicked) return;

    const fontSize=Math.max(8,10*Math.min(scale,1.8));
    const lx=dx, ly=dy-dotR-3;

    if(isRR){
      ctx.font=`${fontSize+2}px sans-serif`; ctx.textAlign='center';
      ctx.fillText('🚻',lx,ly-2);
      return;
    }

    // Room number
    ctx.font=`700 ${fontSize}px 'Space Mono',monospace`;
    ctx.textAlign='center';
    const tw=ctx.measureText(r.id).width;
    const ph=fontSize+5, pw=tw+8;
    const py=ly-ph;

    // Pill background
    ctx.fillStyle='rgba(8,10,16,.88)';
    roundRect(ctx,lx-pw/2,py,pw,ph,3); ctx.fill();
    ctx.strokeStyle=isStart||isEnd?'#ffb34760':'#00e5a040';
    ctx.lineWidth=1; ctx.stroke();

    ctx.fillStyle=isStart||isEnd?'#ffb347':'#00e5a0';
    ctx.fillText(r.id,lx,py+ph-4);

    // Type
    if(r.type_en){
      const tl=r.type_en.length>16?r.type_en.substring(0,15)+'…':r.type_en;
      const tf=Math.max(7,fontSize*0.75);
      ctx.font=`400 ${tf}px 'DM Sans',sans-serif`;
      ctx.fillStyle='rgba(107,117,145,.9)';
      ctx.fillText(tl,lx,py-2);
    }
  });
}

function roundRect(ctx,x,y,w,h,r){
  ctx.beginPath();
  ctx.moveTo(x+r,y); ctx.lineTo(x+w-r,y); ctx.arcTo(x+w,y,x+w,y+r,r);
  ctx.lineTo(x+w,y+h-r); ctx.arcTo(x+w,y+h,x+w-r,y+h,r);
  ctx.lineTo(x+r,y+h); ctx.arcTo(x,y+h,x,y+h-r,r);
  ctx.lineTo(x,y+r); ctx.arcTo(x,y,x+r,y,r); ctx.closePath();
}

// ── Autocomplete ──────────────────────────────────────────────────────────────
function setupAC(inId,drId,onSel){
  const inp=document.getElementById(inId), drp=document.getElementById(drId);
  inp.addEventListener('input',()=>{
    const q=inp.value.trim().toLowerCase(); if(!q){drp.classList.remove('show');return;}
    const list=allRooms.filter(r=>r.id.toLowerCase().includes(q)||r.type.toLowerCase().includes(q)).slice(0,12);
    drp.innerHTML=list.map(r=>`<div class="di" data-id="${r.id}"><div><span class="rid">${r.id}</span> <span style="color:var(--muted);font-size:10px">${r.type||''}</span></div><div class="rinfo">B${r.building}·F${r.floor}</div></div>`).join('');
    drp.querySelectorAll('.di').forEach(el=>el.addEventListener('click',()=>{
      const room=list.find(r=>r.id===el.dataset.id);
      inp.value=`${room.id} — ${room.type||'Room'}`;
      drp.classList.remove('show'); onSel(room);
    }));
    drp.classList.toggle('show',list.length>0);
  });
  document.addEventListener('click',e=>{if(!inp.contains(e.target)&&!drp.contains(e.target))drp.classList.remove('show');});
}

function checkReady(){document.getElementById('routeBtn').disabled=!(fromRoom&&toRoom);}

function swapRooms(){
  const fi=document.getElementById('fromInput'),ti=document.getElementById('toInput');
  [fi.value,ti.value]=[ti.value,fi.value];[fromRoom,toRoom]=[toRoom,fromRoom];
  checkReady(); draw();
}

// ── Route ─────────────────────────────────────────────────────────────────────
async function getRoute(){
  if(!fromRoom||!toRoom)return;
  const btn=document.getElementById('routeBtn'),err=document.getElementById('errBanner'),area=document.getElementById('stepsArea');
  btn.disabled=true; err.classList.remove('show');
  area.innerHTML='<div class="loading"><div class="spin"></div>Finding shortest path…</div>';
  try{
    const res=await fetch(`${API}/api/route4?from_room=${fromRoom.id}&to_room=${toRoom.id}`);
    const data=await res.json();
    if(!res.ok){err.textContent=data.detail||'Route not found';err.classList.add('show');area.innerHTML='';return;}
    currentRoute=data; currentRoute.roomSet=new Set([data.from_room, data.to_room]);
    if(fromRoom.floor) await switchFloor(fromRoom.floor);
    else draw();
    renderSteps(data);
  }catch(e){err.textContent='Cannot connect to server.';err.classList.add('show');area.innerHTML='';}
  finally{btn.disabled=false;}
}

function renderSteps(data){
  const area=document.getElementById('stepsArea');
  const ICO={start:'📍',walk:'→',stairs:'↕',elevator:'🛗',arrived:'🏁'};
  const floors=data.floor_changes||0;
  const walks =data.num_corridors||0;

  const html=data.steps.map(s=>{
    const floorBtn=(s.type==='stairs'||s.type==='elevator')
      ?`<button class="floor-btn" onclick="goFloor('${s.room}')">View floor →</button>`:'';
    return`<div class="step"><div class="sline"></div><div class="sico ${s.type}">${ICO[s.type]||'·'}</div><div style="flex:1;padding:4px 0"><div class="stxt ${s.type}">${s.text}</div>${floorBtn}</div></div>`;
  }).join('');

  area.innerHTML=`
    <div class="summary">
      <div class="stat"><div class="sv">${data.num_corridors}</div><div class="sk">Corridor pts</div></div>
      <div class="sdiv"></div>
      <div class="stat"><div class="sv">${walks}</div><div class="sk">Walk</div></div>
      <div class="sdiv"></div>
      <div class="stat"><div class="sv">${floors}</div><div class="sk">Floors</div></div>
    </div>
    <div class="steps-lbl">Directions</div>${html}`;
}

async function goFloor(roomId){
  const r=allRooms.find(x=>x.id===roomId);
  if(r&&r.floor) await switchFloor(r.floor);
}

// ── Pan/Zoom ──────────────────────────────────────────────────────────────────
function setupPan(){
  canvas.addEventListener('mousedown',e=>{isPan=true;lmx=e.clientX;lmy=e.clientY;});
  canvas.addEventListener('mousemove',e=>{if(!isPan)return;panX+=e.clientX-lmx;panY+=e.clientY-lmy;lmx=e.clientX;lmy=e.clientY;draw();});
  canvas.addEventListener('mouseup',()=>isPan=false);
  canvas.addEventListener('mouseleave',()=>isPan=false);
  canvas.addEventListener('wheel',e=>{
    e.preventDefault();
    const f=e.deltaY<0?1.12:.9;
    const rect=canvas.getBoundingClientRect();
    const mx=e.clientX-rect.left,my=e.clientY-rect.top;
    panX=mx-(mx-panX)*f; panY=my-(my-panY)*f;
    scale=Math.max(.25,Math.min(8,scale*f)); draw();
  },{passive:false});
}
function zoomIn(){scale=Math.min(8,scale*1.2);draw();}
function zoomOut(){scale=Math.max(.25,scale/1.2);draw();}
function resetView(){panX=0;panY=0;scale=1;draw();}

window.addEventListener('load',init);
</script>
<script>
window.addEventListener('DOMContentLoaded', () => {
  const fIn = document.getElementById('fromInput');
  const tIn = document.getElementById('toInput');
  
  // הוספת מחיקה מהירה ב-Focus
  if(fIn) {
    fIn.value = "21403";
    fIn.onfocus = (e) => e.target.select();
  }
  if(tIn) {
    tIn.value = "21201";
    tIn.onfocus = (e) => e.target.select();
  }

  // הגדרה אוטומטית של המשתנים כדי שהכפתור יעבוד
  // אנחנו מניחים שהחדרים קיימים ברשימת ה-allRooms שנשמרת מהשרת
  setTimeout(() => {
    if(typeof allRooms !== 'undefined') {
      fromRoom = allRooms.find(r => r.id === "21403") || null;
      toRoom = allRooms.find(r => r.id === "21201") || null;
      checkReady(); // זה יפעיל מחדש את הכפתור
    }
  }, 1000); // מחכים שנייה שהשרת יחזיר את רשימת החדרים
});
</script>
<script>
window.addEventListener('load', () => {
  const fromIn = document.getElementById('fromInput');
  const toIn = document.getElementById('toInput');
  
  // הגדרת ערכים
  if(fromIn) {
      fromIn.value = "21403";
      fromIn.onfocus = (e) => e.target.select();
  }
  if(toIn) {
      toIn.value = "21201";
      toIn.onfocus = (e) => e.target.select();
  }
});
</script>
</body>
</html>
