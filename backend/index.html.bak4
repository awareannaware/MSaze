<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Campus Navigator</title>
<style>
:root{
  --bg:#0d0f14;--surface:#161920;--surface2:#1e2230;--border:#2a2f3d;
  --accent:#4f9eff;--accent2:#00e5a0;--warn:#ffb347;
  --text:#e8ecf4;--muted:#6b7591;
  --wall21:#c8d8f0;--wall22:#f0c8a0;
  --route:#00e5a0;--start:#ffb347;--stairs:#bf7fff;
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;overflow:hidden;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:var(--bg);color:var(--text)}

/* ── Header ── */
header{height:48px;display:flex;align-items:center;gap:10px;padding:0 16px;background:var(--surface);border-bottom:1px solid var(--border);flex-shrink:0;z-index:10}
.logo{font-family:'Courier New',monospace;font-size:15px;font-weight:700;color:var(--accent)}.logo span{color:var(--accent2)}
.sub{font-size:10px;color:var(--muted);margin-left:4px}

/* ── Layout ── */
#app{display:flex;flex-direction:column;height:100%}
.layout{display:flex;flex:1;overflow:hidden}

/* ── Panel (desktop) ── */
#panel{width:340px;flex-shrink:0;background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;overflow:hidden}

/* ── Tab bar ── */
#tab-bar{display:flex;border-bottom:1px solid var(--border);flex-shrink:0}
.tab-btn{flex:1;padding:10px 6px;font-size:11px;font-weight:600;letter-spacing:.6px;text-transform:uppercase;color:var(--muted);background:none;border:none;border-bottom:2px solid transparent;cursor:pointer;transition:all .2s}
.tab-btn.active{color:var(--accent);border-bottom-color:var(--accent)}
.tab-btn:hover:not(.active){color:var(--text)}

/* ── Tab content ── */
.tab-content{flex:1;overflow-y:auto;padding:14px}
.tab-content::-webkit-scrollbar{width:3px}
.tab-content::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}

/* ── Form inputs ── */
.lbl{font-size:9px;font-weight:700;letter-spacing:1.4px;text-transform:uppercase;color:var(--muted);margin-bottom:5px;display:block}
.inp-wrap{position:relative;margin-bottom:10px}
.inp-ico{position:absolute;left:9px;top:50%;transform:translateY(-50%);font-size:12px;pointer-events:none}
input[type=text]{width:100%;background:var(--surface2);border:1px solid var(--border);border-radius:8px;color:var(--text);font-size:13px;padding:9px 9px 9px 30px;outline:none;transition:border-color .2s}
input[type=text]:focus{border-color:var(--accent)}
input[type=text]::placeholder{color:var(--muted)}

/* ── Dropdown ── */
.drop{position:absolute;top:calc(100% + 3px);left:0;right:0;background:var(--surface2);border:1px solid var(--border);border-radius:8px;max-height:180px;overflow-y:auto;z-index:500;display:none;box-shadow:0 8px 24px rgba(0,0,0,.5)}
.drop.show{display:block}
.drop::-webkit-scrollbar{width:3px}.drop::-webkit-scrollbar-thumb{background:var(--border)}
.di{padding:8px 11px;cursor:pointer;font-size:12px;display:flex;justify-content:space-between;align-items:center;gap:8px;transition:background .1s}
.di:hover,.di.focused{background:var(--border)}
.rid{font-family:'Courier New',monospace;font-size:11px;color:var(--accent);font-weight:700;white-space:nowrap}
.rinfo{font-size:10px;color:var(--muted);text-align:right}

/* ── Buttons ── */
.swap-btn{width:100%;background:transparent;border:1px dashed var(--border);border-radius:7px;color:var(--muted);font-size:11px;padding:6px;cursor:pointer;transition:all .2s;margin-bottom:10px}
.swap-btn:hover{border-color:var(--accent2);color:var(--accent2)}
.route-btn{width:100%;background:var(--accent);border:none;border-radius:8px;color:#0d0f14;font-size:13px;font-weight:700;padding:11px;cursor:pointer;transition:all .2s;display:flex;align-items:center;justify-content:center;gap:6px}
.route-btn:hover{background:#74b3ff;transform:translateY(-1px)}
.route-btn:disabled{opacity:.4;cursor:not-allowed;transform:none}

/* ── Error banner ── */
#error-banner{display:none;margin-top:10px;padding:9px 12px;background:#2a1a1a;border:1px solid #7f3030;border-radius:7px;font-size:12px;color:#ff7070}

/* ── Summary chips ── */
.summary{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:12px}
.chip{padding:4px 10px;border-radius:20px;font-size:11px;font-weight:600;background:var(--surface2);border:1px solid var(--border);color:var(--muted)}
.chip.green{border-color:var(--accent2);color:var(--accent2)}
.chip.orange{border-color:var(--warn);color:var(--warn)}

/* ── Multi-floor banner ── */
#floor-banner{display:none;margin-bottom:10px;padding:8px 12px;background:#1a1f2e;border:1px solid var(--accent);border-radius:8px;font-size:12px;color:var(--accent)}

/* ── Steps list ── */
.step-item{display:flex;gap:10px;padding:8px 0;border-bottom:1px solid #1a1f2a;cursor:default}
.step-item:last-child{border-bottom:none}
.step-ico{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0;margin-top:1px}
.step-ico.start{background:#2a2000;border:1px solid var(--warn)}
.step-ico.walk{background:#0d1f1a;border:1px solid var(--accent2)}
.step-ico.stairs{background:#1e1030;border:1px solid var(--stairs)}
.step-ico.elevator{background:#1e1030;border:1px solid var(--stairs)}
.step-ico.arrived{background:#0d1f0d;border:1px solid var(--accent2)}
.step-text{flex:1;font-size:12px;line-height:1.5;color:var(--text);padding-top:4px}
.floor-link{display:inline-block;margin-top:4px;font-size:10px;color:var(--accent);cursor:pointer;text-decoration:underline}
.floor-link:hover{color:#74b3ff}

/* ── Map area ── */
#map-wrap{flex:1;position:relative;overflow:hidden;background:var(--bg)}
canvas#map{display:block;touch-action:none}

/* ── Floor tabs ── */
#floor-tabs{position:absolute;top:10px;left:50%;transform:translateX(-50%);display:flex;gap:4px;z-index:20;background:rgba(13,15,20,.85);padding:4px;border-radius:10px;border:1px solid var(--border);backdrop-filter:blur(8px)}
.ftab{padding:5px 13px;border-radius:7px;font-size:12px;font-weight:600;cursor:pointer;color:var(--muted);background:none;border:none;transition:all .2s}
.ftab.active{background:var(--accent);color:#0d0f14}
.ftab:hover:not(.active){color:var(--text);background:var(--surface2)}

/* ── Map control buttons ── */
#map-btns{position:absolute;bottom:16px;right:16px;display:flex;flex-direction:column;gap:6px;z-index:20}
.map-btn{width:36px;height:36px;background:var(--surface);border:1px solid var(--border);border-radius:8px;color:var(--text);font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s}
.map-btn:hover{background:var(--surface2);border-color:var(--accent)}

/* ── Admin table ── */
.admin-section{margin-bottom:18px}
.admin-section h3{font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--muted);margin-bottom:8px}
.admin-total{font-size:28px;font-weight:700;color:var(--accent2);margin-bottom:4px}
table{width:100%;border-collapse:collapse;font-size:11px}
th{text-align:left;padding:4px 6px;color:var(--muted);border-bottom:1px solid var(--border)}
td{padding:4px 6px;border-bottom:1px solid #1a1f2a;font-family:'Courier New',monospace;font-size:11px}
tr:hover td{background:var(--surface2)}

/* ── Mobile layout ── */
@media (max-width:767px){
  .layout{flex-direction:column}
  #map-wrap{flex:none;height:55vh}
  #panel{width:100%;flex:1;border-right:none;border-top:1px solid var(--border);overflow:hidden}
}

/* ── Loading spinner ── */
.spinner{display:inline-block;width:14px;height:14px;border:2px solid rgba(255,255,255,.2);border-top-color:#fff;border-radius:50%;animation:spin .7s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
</style>
</head>
<body>
<div id="app">
  <header>
    <span class="logo">campus<span>nav</span></span>
    <span class="sub">Indoor Navigation</span>
  </header>
  <div class="layout">
    <div id="panel">
      <div id="tab-bar">
        <button class="tab-btn active" onclick="showTab('search')">Search</button>
        <button class="tab-btn" id="tab-btn-directions" onclick="showTab('directions')">Directions</button>
        <button class="tab-btn" id="tab-btn-admin" style="display:none" onclick="showTab('admin')">Analytics</button>
      </div>

      <!-- Search tab -->
      <div class="tab-content" id="tab-search">
        <label class="lbl">From</label>
        <div class="inp-wrap" id="from-wrap">
          <span class="inp-ico">📍</span>
          <input type="text" id="from-inp" placeholder="Room number or type..." autocomplete="off">
          <div class="drop" id="from-drop"></div>
        </div>
        <label class="lbl">To</label>
        <div class="inp-wrap" id="to-wrap">
          <span class="inp-ico">🏁</span>
          <input type="text" id="to-inp" placeholder="Room number or type..." autocomplete="off">
          <div class="drop" id="to-drop"></div>
        </div>
        <button class="swap-btn" onclick="swapRooms()">⇅ Swap</button>
        <button class="route-btn" id="route-btn" onclick="findRoute()">
          <span id="route-btn-text">Find Route</span>
        </button>
        <div id="error-banner"></div>
      </div>

      <!-- Directions tab -->
      <div class="tab-content" id="tab-directions" style="display:none">
        <div class="summary" id="summary"></div>
        <div id="floor-banner"></div>
        <div id="steps-list"></div>
      </div>

      <!-- Admin tab -->
      <div class="tab-content" id="tab-admin" style="display:none">
        <div id="admin-content"><p style="color:var(--muted);font-size:12px">Loading analytics...</p></div>
      </div>
    </div>

    <div id="map-wrap">
      <div id="floor-tabs">
        <button class="ftab" onclick="switchFloor(1)">F1</button>
        <button class="ftab" onclick="switchFloor(2)">F2</button>
        <button class="ftab active" onclick="switchFloor(3)">F3</button>
        <button class="ftab" onclick="switchFloor(4)">F4</button>
        <button class="ftab" onclick="switchFloor(5)">F5</button>
        <button class="ftab" onclick="switchFloor(6)">F6</button>
      </div>
      <canvas id="map"></canvas>
      <div id="map-btns">
        <button class="map-btn" title="Zoom in" onclick="zoomMap(1.25)">+</button>
        <button class="map-btn" title="Zoom out" onclick="zoomMap(0.8)">−</button>
        <button class="map-btn" title="Reset view" onclick="resetView()">⌂</button>
      </div>
    </div>
  </div>
</div>

<script>
// ────────────────────────────────────────────────────────────────────────────
// State
// ────────────────────────────────────────────────────────────────────────────
let ALL_ROOMS = [];
let currentFloor = 3;
let floorData = {};        // floor_num → {walls_b21, walls_b22, rooms, bounds}
let routeData = null;      // last /api/route4 response
let fromRoom = null, toRoom = null;

// View transform
let camX = 0, camY = 0, camScale = 1;
let viewInited = false;

// Admin
const urlParams = new URLSearchParams(location.search);
const adminToken = urlParams.get('admin');
if (adminToken) {
  document.getElementById('tab-btn-admin').style.display = '';
}

// ────────────────────────────────────────────────────────────────────────────
// Init
// ────────────────────────────────────────────────────────────────────────────
async function init() {
  try {
    const r = await fetch('/api/rooms');
    ALL_ROOMS = await r.json();
  } catch(e) { console.error('Failed to load rooms', e); }
  await loadFloor(currentFloor);
  setupCanvas();
  drawMap();
}
init();

// ────────────────────────────────────────────────────────────────────────────
// Floor data loading
// ────────────────────────────────────────────────────────────────────────────
async function loadFloor(floor) {
  if (floorData[floor]) return floorData[floor];
  try {
    const r = await fetch(`/api/floormap/${floor}`);
    if (!r.ok) return null;
    floorData[floor] = await r.json();
    return floorData[floor];
  } catch(e) { return null; }
}

async function switchFloor(floor) {
  currentFloor = floor;
  document.querySelectorAll('.ftab').forEach((b,i) => b.classList.toggle('active', i+1 === floor));
  viewInited = false;
  await loadFloor(floor);
  drawMap();
}

// ────────────────────────────────────────────────────────────────────────────
// Canvas setup + pan/zoom
// ────────────────────────────────────────────────────────────────────────────
const canvas = document.getElementById('map');
const ctx = canvas.getContext('2d');

function setupCanvas() {
  resizeCanvas();
  window.addEventListener('resize', () => { resizeCanvas(); drawMap(); });

  // Mouse pan/zoom
  let drag = false, lastX, lastY;
  canvas.addEventListener('mousedown', e => { drag=true; lastX=e.clientX; lastY=e.clientY; canvas.style.cursor='grabbing'; });
  window.addEventListener('mouseup', () => { drag=false; canvas.style.cursor='default'; });
  canvas.addEventListener('mousemove', e => {
    if (!drag) return;
    camX += e.clientX-lastX; camY += e.clientY-lastY;
    lastX=e.clientX; lastY=e.clientY; drawMap();
  });
  canvas.addEventListener('wheel', e => {
    e.preventDefault();
    const factor = e.deltaY < 0 ? 1.12 : 0.88;
    const rect = canvas.getBoundingClientRect();
    const mx = e.clientX - rect.left, my = e.clientY - rect.top;
    camX = mx - (mx-camX)*factor;
    camY = my - (my-camY)*factor;
    camScale *= factor;
    drawMap();
  }, {passive:false});

  // Touch pan/zoom
  let touches = [], pinchDist0 = null, pinchCamScale0 = null;
  canvas.addEventListener('touchstart', e => {
    e.preventDefault();
    touches = [...e.touches];
    if (e.touches.length === 2) {
      pinchDist0 = Math.hypot(e.touches[0].clientX-e.touches[1].clientX, e.touches[0].clientY-e.touches[1].clientY);
      pinchCamScale0 = camScale;
    }
  }, {passive:false});
  canvas.addEventListener('touchmove', e => {
    e.preventDefault();
    if (e.touches.length === 2 && pinchDist0) {
      const d = Math.hypot(e.touches[0].clientX-e.touches[1].clientX, e.touches[0].clientY-e.touches[1].clientY);
      const cx = (e.touches[0].clientX+e.touches[1].clientX)/2;
      const cy = (e.touches[0].clientY+e.touches[1].clientY)/2;
      const rect = canvas.getBoundingClientRect();
      const mx = cx-rect.left, my = cy-rect.top;
      const factor = d/pinchDist0;
      camScale = pinchCamScale0 * factor;
      camX = mx - (mx-camX)*factor;
      camY = my - (my-camY)*factor;
      touches = [...e.touches];
    } else if (e.touches.length === 1 && touches.length >= 1) {
      camX += e.touches[0].clientX - touches[0].clientX;
      camY += e.touches[0].clientY - touches[0].clientY;
      touches = [...e.touches];
    }
    drawMap();
  }, {passive:false});
  canvas.addEventListener('touchend', e => { touches=[...e.touches]; if(e.touches.length<2) pinchDist0=null; });
}

function resizeCanvas() {
  const wrap = document.getElementById('map-wrap');
  canvas.width = wrap.clientWidth;
  canvas.height = wrap.clientHeight;
}

function resetView() {
  viewInited = false;
  drawMap();
}

function zoomMap(factor) {
  const cx = canvas.width/2, cy = canvas.height/2;
  camX = cx - (cx-camX)*factor;
  camY = cy - (cy-camY)*factor;
  camScale *= factor;
  drawMap();
}

// DXF/world coordinates: Y increases upward.
// Canvas coordinates: Y increases downward.
// We must flip Y: screen_y = -world_y * scale + camY
function worldToScreen(x, y) {
  return [x * camScale + camX, -y * camScale + camY];
}

function initViewForFloor(data) {
  if (!data || !data.bounds) return;
  const b = data.bounds;
  const fw = b.x_max - b.x_min, fh = b.y_max - b.y_min;
  if (fw <= 0 || fh <= 0) return;
  const pad = 40;
  const sx = (canvas.width - pad*2) / fw;
  const sy = (canvas.height - pad*2) / fh;
  camScale = Math.min(sx, sy);
  // x_min → pad  (left edge)
  camX = pad - b.x_min * camScale;
  // y_max → pad  (top edge, because y is flipped)
  camY = pad + b.y_max * camScale;
  viewInited = true;
}

// ────────────────────────────────────────────────────────────────────────────
// Draw
// ────────────────────────────────────────────────────────────────────────────
function drawMap() {
  ctx.clearRect(0, 0, canvas.width, canvas.height);
  ctx.fillStyle = '#0d0f14';
  ctx.fillRect(0, 0, canvas.width, canvas.height);

  const data = floorData[currentFloor];
  if (!data) return;

  if (!viewInited) initViewForFloor(data);

  ctx.save();

  // ── Walls ──
  const wallsB21 = data.walls_b21 || [];
  const wallsB22 = data.walls_b22 || [];

  ctx.lineWidth = 1.2;
  ctx.strokeStyle = 'rgba(200,216,240,0.55)';
  ctx.beginPath();
  for (const w of wallsB21) {
    const [sx,sy] = worldToScreen(w.start[0], w.start[1]);
    const [ex,ey] = worldToScreen(w.end[0], w.end[1]);
    ctx.moveTo(sx, sy); ctx.lineTo(ex, ey);
  }
  ctx.stroke();

  ctx.strokeStyle = 'rgba(240,200,160,0.55)';
  ctx.beginPath();
  for (const w of wallsB22) {
    const [sx,sy] = worldToScreen(w.start[0], w.start[1]);
    const [ex,ey] = worldToScreen(w.end[0], w.end[1]);
    ctx.moveTo(sx, sy); ctx.lineTo(ex, ey);
  }
  ctx.stroke();

  // ── Door dots ──
  ctx.fillStyle = 'rgba(107,117,145,0.5)';
  for (const room of (data.rooms || [])) {
    if (room.door_x == null) continue;
    const [sx,sy] = worldToScreen(room.door_x, room.door_y);
    ctx.beginPath();
    ctx.arc(sx, sy, 2 * camScale, 0, Math.PI*2);
    ctx.fill();
  }

  // ── Route path for current floor ──
  if (routeData) {
    const pts = (routeData.corridor_path || []).filter(p => p.floor === currentFloor);

    // Split into sub-segments at floor_change markers
    const segments = [];
    let cur = [];
    for (const p of pts) {
      if (p.is_floor_start && cur.length > 0) {
        segments.push(cur); cur = [];
      }
      cur.push(p);
      if (p.is_floor_change) {
        segments.push(cur); cur = [];
      }
    }
    if (cur.length) segments.push(cur);

    for (const seg of segments) {
      if (seg.length < 2) continue;
      // Glow
      ctx.beginPath();
      ctx.strokeStyle = 'rgba(0,229,160,0.18)';
      ctx.lineWidth = 10 * Math.max(camScale, 0.5);
      ctx.lineJoin = 'round';
      ctx.lineCap = 'round';
      for (let i = 0; i < seg.length; i++) {
        const [sx,sy] = worldToScreen(seg[i].x, seg[i].y);
        i === 0 ? ctx.moveTo(sx,sy) : ctx.lineTo(sx,sy);
      }
      ctx.stroke();
      // Main line
      ctx.beginPath();
      ctx.strokeStyle = '#00e5a0';
      ctx.lineWidth = 2.5 * Math.max(camScale, 0.5);
      for (let i = 0; i < seg.length; i++) {
        const [sx,sy] = worldToScreen(seg[i].x, seg[i].y);
        i === 0 ? ctx.moveTo(sx,sy) : ctx.lineTo(sx,sy);
      }
      ctx.stroke();
    }

    // Stairs markers at floor_change points
    const allPts = routeData.corridor_path || [];
    for (const p of allPts) {
      if (p.floor !== currentFloor) continue;
      if (p.is_floor_change || p.is_floor_start) {
        const [sx,sy] = worldToScreen(p.x, p.y);
        ctx.beginPath();
        ctx.arc(sx, sy, 8 * Math.max(camScale, 0.5), 0, Math.PI*2);
        ctx.fillStyle = '#bf7fff';
        ctx.fill();
        ctx.font = `${Math.max(8, 11*camScale)}px sans-serif`;
        ctx.fillStyle = '#fff';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText('↕', sx, sy);
      }
    }

    // Start marker
    const frNode = getNodeFromFloor(routeData.from_room, data);
    if (frNode) drawRoomMarker(frNode, routeData.from_room, '#ffb347');

    // End marker
    const trNode = getNodeFromFloor(routeData.to_room, data);
    if (trNode) drawRoomMarker(trNode, routeData.to_room, '#ffb347');
  }

  ctx.restore();
}

function getNodeFromFloor(roomId, data) {
  if (!data) return null;
  return (data.rooms || []).find(r => r.id === roomId);
}

function drawRoomMarker(room, label, color) {
  const x = room.door_x != null ? room.door_x : room.x;
  const y = room.door_y != null ? room.door_y : room.y;
  if (x == null) return;
  const [sx,sy] = worldToScreen(x, y);
  const r = Math.max(5, 7 * camScale);
  ctx.beginPath();
  ctx.arc(sx, sy, r, 0, Math.PI*2);
  ctx.fillStyle = color;
  ctx.fill();
  ctx.strokeStyle = '#fff';
  ctx.lineWidth = 1.5;
  ctx.stroke();
  // Label
  const fs = Math.max(9, 11*camScale);
  ctx.font = `700 ${fs}px sans-serif`;
  ctx.fillStyle = '#fff';
  ctx.strokeStyle = '#0d0f14';
  ctx.lineWidth = 3;
  ctx.textAlign = 'center';
  ctx.textBaseline = 'bottom';
  ctx.strokeText(label, sx, sy - r - 2);
  ctx.fillText(label, sx, sy - r - 2);
}

// ────────────────────────────────────────────────────────────────────────────
// Autocomplete
// ────────────────────────────────────────────────────────────────────────────
const SKIP_TYPES = ['stairwell','elevator','shaft','elevator shaft'];

function isSkipType(t) {
  const tl = (t||'').toLowerCase();
  return SKIP_TYPES.some(s => tl.includes(s));
}

function setupAutocomplete(inputId, dropId, onSelect) {
  const inp = document.getElementById(inputId);
  const drop = document.getElementById(dropId);
  let focusIdx = -1;

  inp.addEventListener('input', () => {
    const q = inp.value.trim().toLowerCase();
    if (!q) { drop.classList.remove('show'); return; }
    const matches = ALL_ROOMS.filter(r => {
      if (isSkipType(r.type)) return false;
      return r.id.toLowerCase().includes(q) || (r.type||'').toLowerCase().includes(q);
    }).slice(0, 30);
    if (!matches.length) { drop.classList.remove('show'); return; }
    focusIdx = -1;
    drop.innerHTML = matches.map((r,i) =>
      `<div class="di" data-id="${r.id}" data-i="${i}">
        <span class="rid">${r.id}</span>
        <span class="rinfo">${r.type||''} · F${r.floor_num||r.floor||'?'}</span>
      </div>`
    ).join('');
    drop.classList.add('show');
    drop.querySelectorAll('.di').forEach(el => {
      el.addEventListener('mousedown', e => {
        e.preventDefault();
        onSelect(el.dataset.id, inp);
        drop.classList.remove('show');
      });
    });
  });

  inp.addEventListener('keydown', e => {
    const items = drop.querySelectorAll('.di');
    if (e.key === 'ArrowDown') { focusIdx = Math.min(focusIdx+1, items.length-1); highlight(items); e.preventDefault(); }
    else if (e.key === 'ArrowUp') { focusIdx = Math.max(focusIdx-1, 0); highlight(items); e.preventDefault(); }
    else if (e.key === 'Enter') {
      if (focusIdx >= 0 && items[focusIdx]) {
        onSelect(items[focusIdx].dataset.id, inp);
        drop.classList.remove('show');
      }
    } else if (e.key === 'Escape') { drop.classList.remove('show'); }
  });

  function highlight(items) {
    items.forEach((el,i) => el.classList.toggle('focused', i===focusIdx));
    if (items[focusIdx]) items[focusIdx].scrollIntoView({block:'nearest'});
  }

  document.addEventListener('click', e => {
    if (!inp.contains(e.target) && !drop.contains(e.target)) drop.classList.remove('show');
  });
}

setupAutocomplete('from-inp', 'from-drop', (id, inp) => { fromRoom = id; inp.value = id; });
setupAutocomplete('to-inp', 'to-drop', (id, inp) => { toRoom = id; inp.value = id; });

function swapRooms() {
  [fromRoom, toRoom] = [toRoom, fromRoom];
  document.getElementById('from-inp').value = fromRoom||'';
  document.getElementById('to-inp').value = toRoom||'';
}

// ────────────────────────────────────────────────────────────────────────────
// Tab switching
// ────────────────────────────────────────────────────────────────────────────
function showTab(name) {
  ['search','directions','admin'].forEach(t => {
    document.getElementById(`tab-${t}`).style.display = t===name?'':'none';
    const btn = document.querySelector(`.tab-btn[onclick="showTab('${t}')"]`);
    if (btn) btn.classList.toggle('active', t===name);
  });
  if (name === 'admin') loadAdminStats();
}

// ────────────────────────────────────────────────────────────────────────────
// Route finding
// ────────────────────────────────────────────────────────────────────────────
async function findRoute() {
  const fi = document.getElementById('from-inp').value.trim();
  const ti = document.getElementById('to-inp').value.trim();
  if (fi) fromRoom = fi;
  if (ti) toRoom = ti;

  const errBanner = document.getElementById('error-banner');
  errBanner.style.display = 'none';

  if (!fromRoom || !toRoom) {
    errBanner.textContent = 'Please select both a starting room and a destination.';
    errBanner.style.display = '';
    return;
  }

  const btn = document.getElementById('route-btn');
  const btnText = document.getElementById('route-btn-text');
  btn.disabled = true;
  btnText.innerHTML = '<span class="spinner"></span> Finding route...';

  try {
    const r = await fetch(`/api/route4?from_room=${encodeURIComponent(fromRoom)}&to_room=${encodeURIComponent(toRoom)}`);
    const data = await r.json();
    if (!r.ok) throw new Error(data.detail || 'Route not found');
    routeData = data;
    renderDirections(data);
    showTab('directions');
    // Switch to start floor
    if (data.corridor_path && data.corridor_path.length > 0) {
      const startFloor = data.corridor_path[0].floor;
      await switchFloor(startFloor);
    }
    drawMap();
  } catch(e) {
    errBanner.textContent = e.message;
    errBanner.style.display = '';
  } finally {
    btn.disabled = false;
    btnText.textContent = 'Find Route';
  }
}

function renderDirections(data) {
  const summary = document.getElementById('summary');
  const stepsEl = document.getElementById('steps-list');
  const bannerEl = document.getElementById('floor-banner');

  const fc = data.floor_changes || 0;
  const nc = data.num_corridors || 0;
  summary.innerHTML = `
    <span class="chip green">${nc} waypoints</span>
    <span class="chip ${fc>0?'orange':'green'}">${fc} floor change${fc!==1?'s':''}</span>
  `;

  // Multi-floor banner
  if (fc > 0) {
    const floors = [];
    let pf = null;
    for (const p of (data.corridor_path||[])) {
      if (p.floor !== pf) { floors.push(p.floor); pf = p.floor; }
    }
    bannerEl.textContent = `Route spans floors ${floors.join('→')} — tap ↕ to switch`;
    bannerEl.style.display = '';
  } else {
    bannerEl.style.display = 'none';
  }

  const ICONS = { start:'📍', walk:'→', stairs:'↕', elevator:'🛗', arrived:'🏁' };
  const steps = data.steps || [];
  stepsEl.innerHTML = steps.map((s,i) => {
    const ico = ICONS[s.type] || '•';
    let floorLink = '';
    if ((s.type==='stairs'||s.type==='elevator') && s.floor != null) {
      floorLink = `<span class="floor-link" onclick="switchFloor(${s.floor})">View floor ${s.floor} →</span>`;
    }
    return `<div class="step-item">
      <div class="step-ico ${s.type}">${ico}</div>
      <div class="step-text">${escHtml(s.text)}${floorLink}</div>
    </div>`;
  }).join('');
}

function escHtml(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

// ────────────────────────────────────────────────────────────────────────────
// Admin analytics
// ────────────────────────────────────────────────────────────────────────────
async function loadAdminStats() {
  if (!adminToken) return;
  const el = document.getElementById('admin-content');
  try {
    const r = await fetch(`/api/admin/stats?token=${encodeURIComponent(adminToken)}`);
    if (!r.ok) { el.innerHTML = '<p style="color:#ff7070;font-size:12px">Access denied</p>'; return; }
    const d = await r.json();
    el.innerHTML = `
      <div class="admin-section">
        <div class="admin-total">${d.total_searches}</div>
        <h3>Total Searches</h3>
      </div>
      <div class="admin-section">
        <h3>Top Routes</h3>
        <table>
          <thead><tr><th>From</th><th>To</th><th>Count</th></tr></thead>
          <tbody>${(d.top_routes||[]).map(r=>`<tr><td>${escHtml(r.from)}</td><td>${escHtml(r.to)}</td><td>${r.count}</td></tr>`).join('')}</tbody>
        </table>
      </div>
      <div class="admin-section">
        <h3>Recent Searches</h3>
        <table>
          <thead><tr><th>From</th><th>To</th><th>Changes</th><th>Time</th></tr></thead>
          <tbody>${(d.recent||[]).map(r=>`<tr><td>${escHtml(r.from)}</td><td>${escHtml(r.to)}</td><td>${r.floor_changes??''}</td><td style="color:var(--muted)">${escHtml(r.ts||'')}</td></tr>`).join('')}</tbody>
        </table>
      </div>
    `;
  } catch(e) {
    el.innerHTML = `<p style="color:#ff7070;font-size:12px">Error: ${escHtml(e.message)}</p>`;
  }
}
</script>
</body>
</html>
